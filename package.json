{
  "name": "teveroseo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "pnpm -r --filter ./apps/web build",
    "dev": "pnpm --filter @tevero/web dev",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --filter './apps/*' --filter './packages/*' run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze:lengths": "tsx scripts/analyze-translation-lengths.ts apps/web/messages/en.json apps/web/messages/lt.json"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10",
      "esbuild": ">=0.25.0",
      "uuid": ">=14.0.0",
      "@eslint/plugin-kit": ">=0.3.4",
      "typescript": "^5.9.3",
      "vitest": "^4.1.4",
      "fast-uri": ">=3.1.2",
      "hono": ">=4.12.18",
      "mermaid": ">=11.15.0",
      "prismjs": ">=1.30.0",
      "ip-address": ">=10.1.1",
      "protobufjs": ">=7.5.6",
      "basic-ftp": ">=5.3.1",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4"
    }
  },
  "sideEffects": false,
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
