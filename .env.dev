# .env.dev — Local development environment (pre-configured, ready to use)
# Copy to .env.dev.local and add your API keys for full functionality

# ===== REQUIRED FOR FULL FUNCTIONALITY =====
# These are optional for basic UI testing, but needed for AI features

# AI Providers (get from respective dashboards)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Google OAuth (for GSC/Analytics integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# DataForSEO (for SEO audit features)
DATAFORSEO_API_KEY=

# Stripe (for payment features)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (for email features)
RESEND_API_KEY=

# ===== PRE-CONFIGURED (no changes needed) =====
# These have sensible dev defaults

# Encryption keys (dev-only, never use in production)
FERNET_KEY=ZmVybmV0LWRldi1rZXktZm9yLWxvY2FsLW9ubHk9
ASSET_SIGNING_KEY=dev-asset-signing-key-local-only-32ch

# Superadmin secrets encryption key (32 bytes base64)
# Generate new: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY=ZGV2LXNlY3JldHMtZW5jcnlwdGlvbi1rZXktMzJieXRlcw==
