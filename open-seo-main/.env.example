# =============================================================================
# open-seo-main Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# See src/server/lib/runtime-env.ts for validation schema.
#
# Legend:
#   REQUIRED - App will not start without this in production
#   REQUIRED for [feature] - Required only when using specific feature
#   OPTIONAL - App works without this, feature may be degraded
# =============================================================================

# =============================================================================
# REQUIRED IN PRODUCTION
# =============================================================================
# These variables MUST be set for the app to start in production.
# Missing any of these will cause immediate startup failure.
# The app validates these at startup via runtime-env.ts.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# PostgreSQL connection string for open-seo-main database
# SECURITY: Replace YOUR_PASSWORD_HERE with a strong password
# Generate with: openssl rand -base64 32
DATABASE_URL=postgres://postgres:YOUR_PASSWORD_HERE@localhost:5432/open_seo

# Points at AI-Writer's `alwrity` PostgreSQL database on the shared postgres
# instance. Used by open-seo-main for per-client (X-Client-ID) validation (AUTH-03).
# SECURITY: Use the same strong password or a different one for each database
ALWRITY_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/alwrity

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------
# Redis connection string for BullMQ job queues and caching
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Clerk Authentication (REQUIRED)
# -----------------------------------------------------------------------------
# Clerk publishable key - decodes to JWKS URL for JWT verification
# Get from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# -----------------------------------------------------------------------------
# Internal API Key (REQUIRED)
# -----------------------------------------------------------------------------
# Used for service-to-service authentication between apps/web and open-seo-main
# SECURITY: Must be at least 32 characters for cryptographic strength
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# Security Salts & Keys (REQUIRED)
# -----------------------------------------------------------------------------
# Salt for hashing IP addresses (GDPR compliance)
# Used for rate limiting without storing actual IP addresses
# Generate with: openssl rand -hex 32
IP_SALT=

# Encryption key for storing site credentials (WordPress, Shopify, etc.)
# Must be a base64-encoded 32-byte key for AES-256
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SITE_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# AI Services (REQUIRED)
# -----------------------------------------------------------------------------
# Anthropic API key for AI features
# Get from https://console.anthropic.com/settings/keys
# Required for: Voice analysis, keyword intelligence, content analysis
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google OAuth (REQUIRED for GSC/Analytics)
# -----------------------------------------------------------------------------
# Get from https://console.cloud.google.com/apis/credentials
# Required for: Google Search Console, Google Analytics 4 integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Payments (REQUIRED for proposals)
# -----------------------------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
# Required for: Proposal payments, subscription management
STRIPE_SECRET_KEY=
# Get from Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Email Service (REQUIRED for alerts)
# -----------------------------------------------------------------------------
# Get from https://resend.com/api-keys
# Required for: Alert notifications, scheduled reports, user invitations
RESEND_API_KEY=re_your_api_key_here

# -----------------------------------------------------------------------------
# Cron Security (REQUIRED)
# -----------------------------------------------------------------------------
# Secret for authenticating cron job requests
# Used to verify scheduled jobs are triggered by authorized systems
# Generate with: openssl rand -hex 32
CRON_SECRET=

# -----------------------------------------------------------------------------
# WebSocket Configuration (REQUIRED for realtime)
# -----------------------------------------------------------------------------
# Port for WebSocket server (real-time SEO metrics updates)
# Default: 3003
WS_PORT=3003

# =============================================================================
# REQUIRED FOR SPECIFIC FEATURES
# =============================================================================
# These are required when using specific features. The app will start without
# them, but the related features will fail at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# SEO Audits (REQUIRED for DataForSEO features)
# -----------------------------------------------------------------------------
# Base64-encoded "login:password" credentials for DataForSEO API
# Generate with: echo -n "your_login:your_password" | base64
# Required for: SEO audits, keyword research, backlink analysis
DATAFORSEO_API_KEY=

# -----------------------------------------------------------------------------
# AI-Writer Service (REQUIRED for content generation)
# -----------------------------------------------------------------------------
# URL for AI-Writer FastAPI backend
# Format: http://hostname:port
# Required for: Content generation, article workflows
AI_WRITER_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# E-Signature (REQUIRED for proposal signing - Baltic countries)
# -----------------------------------------------------------------------------
# Salt for hashing personal codes (GDPR compliance - e-signature feature)
# Generate with: openssl rand -hex 32
PERSONAL_CODE_SALT=

# Get from https://www.dokobit.com/
# Provides Smart-ID and Mobile-ID signing for Baltic countries
DOKOBIT_ACCESS_TOKEN=

# =============================================================================
# OPTIONAL
# =============================================================================
# These enhance functionality but are not required to start or use the app.
# =============================================================================

# -----------------------------------------------------------------------------
# Environment (OPTIONAL)
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# PDF Generation (OPTIONAL)
# -----------------------------------------------------------------------------
# WebSocket endpoint for remote Puppeteer/Chrome instance
# Required for: PDF report generation when local Chrome is not available
# Format: ws://hostname:port
# PUPPETEER_WS_ENDPOINT=

# -----------------------------------------------------------------------------
# Google AI (OPTIONAL)
# -----------------------------------------------------------------------------
# Get from https://ai.google.dev/
# Uses Gemini 1.5 Pro for Lithuanian proposal generation
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Analytics (OPTIONAL)
# -----------------------------------------------------------------------------
# PostHog analytics for product telemetry
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=

# -----------------------------------------------------------------------------
# Billing (OPTIONAL)
# -----------------------------------------------------------------------------
# Autumn billing integration
AUTUMN_SECRET_KEY=

# -----------------------------------------------------------------------------
# Server Settings (OPTIONAL)
# -----------------------------------------------------------------------------
# PORT=3001
# ALLOWED_HOST=yourdomain.com
# Application URL (used for Stripe redirect URLs)
APP_URL=http://localhost:3001
