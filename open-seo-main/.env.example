# -----------------------------------------------------------------------------
# Core settings
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Clerk publishable key - decodes to JWKS URL for JWT verification
CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SECURITY: Replace YOUR_PASSWORD_HERE with a strong password
# Generate with: openssl rand -base64 32
DATABASE_URL=postgres://postgres:YOUR_PASSWORD_HERE@localhost:5432/open_seo

# Points at AI-Writer's `alwrity` PostgreSQL database on the shared postgres
# instance. Used by open-seo-main for per-client (X-Client-ID) validation (AUTH-03).
# SECURITY: Use the same strong password or a different one for each database
ALWRITY_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/alwrity

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# PostHog analytics (optional)
# -----------------------------------------------------------------------------
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=

# -----------------------------------------------------------------------------
# DataForSEO API (required for SEO audits)
# -----------------------------------------------------------------------------
# Base64-encoded "login:password" credentials
# Generate with: echo -n "your_login:your_password" | base64
# Example: echo -n "user@example.com:mypassword" | base64
DATAFORSEO_API_KEY=

# -----------------------------------------------------------------------------
# Anthropic API (optional - for AI business information extraction)
# Get your API key from https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google AI API (optional - for Lithuanian proposal generation)
# Get your API key from https://ai.google.dev/
# Uses Gemini 1.5 Pro for proposal content generation
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Autumn billing (optional)
# -----------------------------------------------------------------------------
AUTUMN_SECRET_KEY=

# -----------------------------------------------------------------------------
# Dokobit E-Signature (optional - for proposal signing)
# Get your API credentials from https://www.dokobit.com/
# Provides Smart-ID and Mobile-ID signing for Baltic countries
# -----------------------------------------------------------------------------
DOKOBIT_ACCESS_TOKEN=

# Salt for hashing personal codes (GDPR compliance - e-signature feature)
# Generate with: openssl rand -hex 32
PERSONAL_CODE_SALT=

# -----------------------------------------------------------------------------
# Security Salts & Keys (required for production)
# -----------------------------------------------------------------------------
# Salt for hashing IP addresses (GDPR compliance)
# Generate with: openssl rand -hex 32
IP_SALT=

# Internal API key for service-to-service authentication
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# Encryption key for storing site credentials (WordPress, Shopify, etc.)
# Must be a base64-encoded 32-byte key for AES-256
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SITE_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Stripe (optional - for proposal payments)
# Get your API keys from https://dashboard.stripe.com/apikeys
# Webhook secret from https://dashboard.stripe.com/webhooks
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Application URL (used for Stripe redirect URLs)
APP_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Optional server settings
# -----------------------------------------------------------------------------
# PORT=3001
# ALLOWED_HOST=yourdomain.com
