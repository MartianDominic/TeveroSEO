{
  "title": "Scraping Infrastructure",
  "uid": "scraping-infra",
  "timezone": "utc",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Requests per Second",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(scraping_requests_total[5m])",
          "legendFormat": "{{tier}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "gauge",
      "targets": [
        {
          "expr": "rate(scraping_errors_total[5m]) / rate(scraping_requests_total[5m])"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "value": 0, "color": "green" },
          { "value": 0.05, "color": "yellow" },
          { "value": 0.15, "color": "red" }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 3,
      "title": "Daily Cost",
      "type": "stat",
      "targets": [
        {
          "expr": "scraping_cost_daily_total"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 }
    },
    {
      "id": 4,
      "title": "Cache Hit Rate by Level",
      "type": "timeseries",
      "targets": [
        {
          "expr": "scraping_cache_hits_total{level=\"L1\"} / scraping_cache_requests_total{level=\"L1\"}",
          "legendFormat": "L1 Memory"
        },
        {
          "expr": "scraping_cache_hits_total{level=\"L2\"} / scraping_cache_requests_total{level=\"L2\"}",
          "legendFormat": "L2 Redis"
        },
        {
          "expr": "scraping_cache_hits_total{level=\"L3\"} / scraping_cache_requests_total{level=\"L3\"}",
          "legendFormat": "L3 PostgreSQL"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 5,
      "title": "Queue Depth",
      "type": "timeseries",
      "targets": [
        {
          "expr": "scraping_queue_waiting",
          "legendFormat": "Waiting"
        },
        {
          "expr": "scraping_queue_active",
          "legendFormat": "Active"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "title": "Circuit Breaker States",
      "type": "state-timeline",
      "targets": [
        {
          "expr": "scraping_circuit_state",
          "legendFormat": "{{tier}}"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "value": 0, "text": "Closed", "color": "green" },
            { "value": 1, "text": "Open", "color": "red" },
            { "value": 2, "text": "Half-Open", "color": "yellow" }
          ]
        }
      }
    },
    {
      "id": 7,
      "title": "P95 Latency by Tier",
      "type": "heatmap",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(scraping_latency_seconds_bucket[5m]))",
          "legendFormat": "{{tier}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 8,
      "title": "Cost by Tier (Last 7 Days)",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum(increase(scraping_cost_total[7d])) by (tier)"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "id": 9,
      "title": "Requests by Consumer",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(scraping_requests_total[5m]) by (consumer)",
          "legendFormat": "{{consumer}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 10,
      "title": "DataForSEO Budget Usage",
      "type": "gauge",
      "targets": [
        {
          "expr": "scraping_dfs_budget_used_percent"
        }
      ],
      "thresholds": {
        "mode": "absolute",
        "steps": [
          { "value": 0, "color": "green" },
          { "value": 75, "color": "yellow" },
          { "value": 90, "color": "red" }
        ]
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 11,
      "title": "Savings vs Legacy",
      "type": "stat",
      "targets": [
        {
          "expr": "scraping_savings_percentage"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 80, "color": "yellow" },
              { "value": 95, "color": "green" }
            ]
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "tier",
        "type": "query",
        "datasource": "$datasource",
        "query": "label_values(scraping_requests_total, tier)",
        "multi": true,
        "includeAll": true
      },
      {
        "name": "consumer",
        "type": "query",
        "datasource": "$datasource",
        "query": "label_values(scraping_requests_total, consumer)",
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}
