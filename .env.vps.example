# =============================================================================
# .env.vps.example - VPS Production Environment Variables
# =============================================================================
# Copy to .env.vps and fill in real values before `docker compose up`.
# NEVER commit .env.vps (it is listed in .gitignore).
#
# Usage:
#   cp .env.vps.example .env.vps
#   # Edit .env.vps with real secrets
#   docker compose -f docker-compose.vps.yml --env-file .env.vps up -d
#
# Legend:
#   REQUIRED - Services will not start without this
#   REQUIRED for [feature] - Required only when using specific feature
#   OPTIONAL - Services work without this, feature may be degraded
# =============================================================================

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# PostgreSQL passwords for each database
# SECURITY: Generate strong passwords with: openssl rand -base64 32

# Superuser password for PostgreSQL
POSTGRES_PASSWORD=change_me_superuser

# Password for open-seo-main database user
OPEN_SEO_DB_PASSWORD=change_me_openseo

# Password for AI-Writer (alwrity) database user
ALWRITY_DB_PASSWORD=change_me_alwrity

# Connection string for AI-Writer to access alwrity database
# Used by open-seo-main for per-client (X-Client-ID) validation
ALWRITY_DATABASE_URL=postgresql://alwrity:${ALWRITY_DB_PASSWORD}@postgres:5432/alwrity

# =============================================================================
# AUTHENTICATION (REQUIRED)
# =============================================================================
# Clerk authentication - shared across all services
# Get from https://dashboard.clerk.com

# Clerk publishable key (used by open-seo-main for JWT verification)
CLERK_PUBLISHABLE_KEY=pk_live_change_me

# Clerk secret key (used by AI-Writer for server-side auth)
CLERK_SECRET_KEY=sk_live_change_me

# Clerk React publishable key (baked into AI-Writer frontend at build time)
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_live_change_me

# Webhook secret for Clerk webhook verification
# Get from Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET=whsec_change_me

# =============================================================================
# INTERNAL API KEY (REQUIRED)
# =============================================================================
# Shared secret for service-to-service authentication
# SECURITY: Must be at least 32 characters for cryptographic strength
# Used between: apps/web <-> AI-Writer <-> open-seo-main
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change_me_internal_api_key_64_hex

# =============================================================================
# SECURITY SALTS & KEYS (REQUIRED)
# =============================================================================
# Generate all with: openssl rand -hex 32

# Salt for hashing IP addresses (GDPR compliance - rate limiting)
IP_SALT=change_me_ip_salt_32_hex

# Salt for hashing personal codes (GDPR compliance - e-signature)
PERSONAL_CODE_SALT=change_me_personal_code_salt_32_hex

# Encryption key for site credentials (WordPress, Shopify, etc.)
# Must be base64-encoded 32-byte key for AES-256
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SITE_ENCRYPTION_KEY=change_me_site_encryption_key_32_hex

# Fernet key for AI-Writer CMS credentials at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_fernet_key_44_chars

# HMAC key for signing asset URLs (avatars, voice samples)
# Generate with: openssl rand -hex 32
ASSET_SIGNING_KEY=change_me_asset_signing_key_64_hex

# =============================================================================
# OPEN-SEO-MAIN (REQUIRED)
# =============================================================================

# Better Auth configuration
BETTER_AUTH_SECRET=change_me_32_bytes_base64
BETTER_AUTH_URL=https://app.openseo.so

# Auth mode: "hosted" for production, "local_noauth" for dev
OPEN_SEO_AUTH_MODE=hosted

# Cron job authentication secret
# Generate with: openssl rand -hex 32
CRON_SECRET=change_me_cron_secret_64_hex

# =============================================================================
# WEBSOCKET (REQUIRED for realtime)
# =============================================================================
# Port for real-time SEO metrics updates
# Used by activity feed, dashboards, and live metrics
WS_PORT=3002

# =============================================================================
# AI SERVICES (REQUIRED)
# =============================================================================

# Anthropic API key for AI features (voice analysis, keyword intelligence)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-change_me_anthropic_api_key

# Google Gemini API key for content generation (AI-Writer)
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=change_me_gemini_api_key

# =============================================================================
# GOOGLE OAUTH (REQUIRED for GSC/Analytics)
# =============================================================================
# Get from https://console.cloud.google.com/apis/credentials
# Required for: Google Search Console, Google Analytics 4 integration
GOOGLE_CLIENT_ID=change_me_google_client_id
GOOGLE_CLIENT_SECRET=change_me_google_client_secret

# =============================================================================
# PAYMENTS (REQUIRED for billing)
# =============================================================================
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_change_me_stripe_secret_key

# Get from Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_change_me_stripe_webhook_secret

# =============================================================================
# EMAIL SERVICE (REQUIRED for notifications)
# =============================================================================
# Get from https://resend.com/api-keys
# Required for: Alert notifications, scheduled reports, user invitations
RESEND_API_KEY=re_change_me_resend_api_key

# =============================================================================
# SEO AUDITS (REQUIRED for DataForSEO features)
# =============================================================================
# Base64-encoded "login:password" credentials
# Generate with: echo -n "your_login:your_password" | base64
DATAFORSEO_API_KEY=change_me_dataforseo_key

# =============================================================================
# AI-WRITER SETTINGS (REQUIRED)
# =============================================================================

# Environment mode (must be "production" for VPS deployment)
ENVIRONMENT=production

# Security flags (NEVER set to true in production)
ALLOW_UNVERIFIED_JWT_DEV=false

# Subscription enforcement (can be disabled for internal use)
DISABLE_SUBSCRIPTION=true
REACT_APP_DISABLE_SUBSCRIPTION=true

# =============================================================================
# DOMAINS (REQUIRED for nginx/SSL)
# =============================================================================
# Domain for AI-Writer nginx and certbot configuration
AI_WRITER_DOMAIN=app.alwrity.com

# Application URL (used for Stripe redirects, OAuth callbacks)
APP_URL=https://app.tevero.lt

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Email marketing (Loops.so integration)
# Get from https://app.loops.so/settings/api
LOOPS_API_KEY=change_me_loops_api_key

# LightRAG knowledge graph service
# Note: Default port is 8100 (aligned with code defaults)
LIGHTRAG_SERVICE_URL=http://localhost:8100
