# .env.vps.example — copy to .env.vps and fill in real values before `docker compose up`.
# NEVER commit .env.vps (it is listed in .gitignore).
#
# Usage:
#   cp .env.vps.example .env.vps
#   # Edit .env.vps with real secrets
#   docker compose -f docker-compose.vps.yml --env-file .env.vps up -d

# ----- Postgres -----
POSTGRES_PASSWORD=change_me_superuser
OPEN_SEO_DB_PASSWORD=change_me_openseo
ALWRITY_DB_PASSWORD=change_me_alwrity

# ----- open-seo-main -----
BETTER_AUTH_SECRET=change_me_32_bytes_base64
BETTER_AUTH_URL=https://app.openseo.so
OPEN_SEO_AUTH_MODE=hosted          # or local_noauth for dev
DATAFORSEO_API_KEY=change_me_dataforseo_key

# Security: Rate limiting and encryption salts
# Generate with: openssl rand -hex 32
IP_SALT=change_me_ip_salt_32_hex
SITE_ENCRYPTION_KEY=change_me_site_encryption_key_32_hex
PERSONAL_CODE_SALT=change_me_personal_code_salt_32_hex

# Points at AI-Writer's `alwrity` PostgreSQL database on the shared postgres
# instance. Used by open-seo-main for per-client (X-Client-ID) validation (AUTH-03).
ALWRITY_DATABASE_URL=postgresql://alwrity:${ALWRITY_DB_PASSWORD}@postgres:5432/alwrity

# ----- AI-Writer -----
ENVIRONMENT=production
ALLOW_UNVERIFIED_JWT_DEV=false
DISABLE_SUBSCRIPTION=true
CLERK_SECRET_KEY=sk_live_change_me
REACT_APP_CLERK_PUBLISHABLE_KEY=pk_live_change_me
REACT_APP_DISABLE_SUBSCRIPTION=true

# AI Provider: Required for content generation
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=change_me_gemini_api_key

# Encryption: Fernet key for CMS credentials at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_fernet_key_44_chars

# Asset Signing: HMAC key for secure asset URLs (avatars, voice samples)
# Generate with: openssl rand -hex 32
ASSET_SIGNING_KEY=change_me_asset_signing_key_64_hex

# ----- Clerk (shared auth) -----
CLERK_PUBLISHABLE_KEY=pk_live_change_me
# Webhook secret for Clerk webhook verification
# Get from Clerk Dashboard > Webhooks
CLERK_WEBHOOK_SECRET=whsec_change_me

# ----- Internal API Key (service-to-service auth) -----
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=change_me_internal_api_key_64_hex

# ----- Google OAuth (for GSC integration) -----
GOOGLE_CLIENT_ID=change_me_google_client_id
GOOGLE_CLIENT_SECRET=change_me_google_client_secret

# ----- Domains (for nginx SNI / certbot) -----
AI_WRITER_DOMAIN=app.alwrity.com
APP_URL=https://app.tevero.lt

# ----- Email Service -----
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_change_me_resend_api_key

# ----- WebSocket Configuration -----
# Port for real-time dashboard updates (default: 3002)
WS_PORT=3002

# ----- Cron Security -----
# Secret for authenticating cron job requests
# Generate with: openssl rand -hex 32
CRON_SECRET=change_me_cron_secret_64_hex

# ----- LightRAG Service (optional) -----
# URL for the LightRAG knowledge graph service
# Note: Default port is 8100 (aligned with code defaults)
LIGHTRAG_SERVICE_URL=http://localhost:8100

# ----- Stripe (required for payments) -----
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_change_me_stripe_secret_key
# Get from Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_change_me_stripe_webhook_secret

# ----- Anthropic (required for AI features) -----
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-change_me_anthropic_api_key

# ----- Loops (required for email marketing) -----
# Get from https://app.loops.so/settings/api
LOOPS_API_KEY=change_me_loops_api_key
