# .env.vps.example — copy to .env.vps and fill in real values before `docker compose up`.
# NEVER commit .env.vps (it is listed in .gitignore).
#
# Usage:
#   cp .env.vps.example .env.vps
#   # Edit .env.vps with real secrets
#   docker compose -f docker-compose.vps.yml --env-file .env.vps up -d

# ----- Postgres -----
POSTGRES_PASSWORD=change_me_superuser
OPEN_SEO_DB_PASSWORD=change_me_openseo
ALWRITY_DB_PASSWORD=change_me_alwrity

# ----- open-seo-main -----
BETTER_AUTH_SECRET=change_me_32_bytes_base64
BETTER_AUTH_URL=https://app.openseo.so
OPEN_SEO_AUTH_MODE=hosted          # or local_noauth for dev
DATAFORSEO_API_KEY=

# ----- AI-Writer -----
ENVIRONMENT=production
ALLOW_UNVERIFIED_JWT_DEV=false
DISABLE_SUBSCRIPTION=true
CLERK_SECRET_KEY=
REACT_APP_CLERK_PUBLISHABLE_KEY=
REACT_APP_DISABLE_SUBSCRIPTION=true

# ----- Domains (for nginx SNI / certbot) -----
AI_WRITER_DOMAIN=app.alwrity.com
