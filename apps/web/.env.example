# =============================================================================
# apps/web Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# See apps/web/src/lib/env.ts for validation schema.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Database (Required)
# ─────────────────────────────────────────────────────────────────────────────
# SECURITY: Replace YOUR_PASSWORD_HERE with a strong password
# Generate with: openssl rand -base64 32
DATABASE_URL=postgresql://tevero:YOUR_PASSWORD_HERE@localhost:5432/tevero

# ─────────────────────────────────────────────────────────────────────────────
# Redis (Required)
# ─────────────────────────────────────────────────────────────────────────────
# For password-protected Redis: redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# Clerk Authentication (Required)
# Get these from https://dashboard.clerk.com
# ─────────────────────────────────────────────────────────────────────────────
# WARNING: Placeholder values will cause runtime failures!
# PRODUCTION REQUIREMENT: Replace with real keys from Clerk Dashboard.
# Test keys (pk_test_*, sk_test_*) are for development only.
# Production keys (pk_live_*, sk_live_*) are required for deployment.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Clerk URLs (optional, defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/clients
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/clients

# ─────────────────────────────────────────────────────────────────────────────
# Backend Services (Required)
# Server-side URLs for internal API calls
# ─────────────────────────────────────────────────────────────────────────────

# Open SEO Main - Node.js SEO audit platform
# Default: http://localhost:3001
OPEN_SEO_URL=http://localhost:3001

# AI Writer - FastAPI content generation backend
# Default: http://localhost:8000
AI_WRITER_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Public URLs (Optional)
# Client-side URLs for browser API calls
# Required if different from server-side URLs (e.g., through nginx proxy)
# ─────────────────────────────────────────────────────────────────────────────

# Public Open SEO URL for client-side voice API calls
# NEXT_PUBLIC_OPEN_SEO_URL=https://app.openseo.so

# Public AI Writer URL for OAuth redirects
# NEXT_PUBLIC_AI_WRITER_URL=https://api.tevero.io

# Public app URL (used for absolute URLs in emails, etc.)
# NEXT_PUBLIC_APP_URL=https://app.tevero.io

# WebSocket URL for real-time features (required for activity feed)
# Set via build args in docker-compose.vps.yml
# Uses /ws/ path to route through nginx to open-seo WebSocket server (port 3003)
# NEXT_PUBLIC_WS_URL=wss://seowith.tevero.lt/ws

# ─────────────────────────────────────────────────────────────────────────────
# Clerk Webhooks (Required for user sync)
# ─────────────────────────────────────────────────────────────────────────────
# Webhook signing secret from Clerk Dashboard > Webhooks
# SECURITY: Required for webhook signature verification
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Internal API Key (Required in production)
# ─────────────────────────────────────────────────────────────────────────────
# Used for service-to-service authentication between apps/web and backends
# SECURITY: Must be at least 32 characters
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting & Proxy Security (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Secret shared between reverse proxy and app for IP verification
# Prevents attackers from spoofing X-Forwarded-For headers
# Generate with: openssl rand -hex 32
# PROXY_SECRET=

# Set to "true" if running behind Cloudflare (trusts CF-Connecting-IP header)
# TRUST_CLOUDFLARE=false

# ─────────────────────────────────────────────────────────────────────────────
# Health Check Authentication (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Token for authenticated health check requests (exposes detailed metrics)
# Pass via X-Health-Token header to /api/health for full circuit breaker states
# Generate with: openssl rand -hex 32
# HEALTH_CHECK_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Environment (Optional)
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development

# =============================================================================
# Additional Required Variables (Production)
# =============================================================================
# These variables are optional in development but REQUIRED in production.
# The app will fail to start in production if these are missing.

# ─────────────────────────────────────────────────────────────────────────────
# AI Features (Required for proposal generation, content analysis)
# ─────────────────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Stripe (Required for payments/billing)
# ─────────────────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
# STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth (Required for GSC/Analytics integration)
# ─────────────────────────────────────────────────────────────────────────────
# Get from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET

# ─────────────────────────────────────────────────────────────────────────────
# Email Service (Required for notifications)
# ─────────────────────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
# RESEND_API_KEY=re_YOUR_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# Email Marketing (Optional)
# ─────────────────────────────────────────────────────────────────────────────
# Get from https://app.loops.so/settings/api
# LOOPS_API_KEY=YOUR_LOOPS_API_KEY_HERE
