# =============================================================================
# apps/web Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# See apps/web/src/lib/env.ts for validation schema.
#
# Legend:
#   REQUIRED - App will not start without this in production
#   REQUIRED for [feature] - Required only when using specific feature
#   OPTIONAL - App works without this, feature may be degraded
# =============================================================================

# =============================================================================
# REQUIRED IN PRODUCTION
# =============================================================================
# These variables MUST be set for the app to start in production.
# Missing any of these will cause immediate startup failure.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# PostgreSQL connection string for the apps/web database
# SECURITY: Replace YOUR_PASSWORD_HERE with a strong password
# Generate with: openssl rand -base64 32
DATABASE_URL=postgresql://tevero:YOUR_PASSWORD_HERE@localhost:5432/tevero

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------
# Redis connection string for caching and session management
# For password-protected Redis: redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Clerk Authentication (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from https://dashboard.clerk.com
# WARNING: Placeholder values will cause runtime failures!
# PRODUCTION REQUIREMENT: Replace with real keys from Clerk Dashboard.
# Test keys (pk_test_*, sk_test_*) are for development only.
# Production keys (pk_live_*, sk_live_*) are required for deployment.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Clerk URLs (optional, defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/clients
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/clients

# -----------------------------------------------------------------------------
# Backend Service URLs (REQUIRED)
# -----------------------------------------------------------------------------
# Server-side URLs for internal API calls between apps/web and backends

# Open SEO Main - Node.js SEO audit platform
# Format: http://hostname:port
# Default: http://localhost:3001
OPEN_SEO_URL=http://localhost:3001

# AI Writer - FastAPI content generation backend
# Format: http://hostname:port
# Default: http://localhost:8000
AI_WRITER_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# WebSocket URL (REQUIRED for real-time features)
# -----------------------------------------------------------------------------
# WebSocket URL for real-time SEO metrics updates
# Format: ws://hostname:port or wss://hostname/path (for nginx proxy)
# Used by activity feed, real-time dashboards, and live metrics
# Set via build args in docker-compose.vps.yml for production
NEXT_PUBLIC_METRICS_WS_URL=ws://localhost:3003

# -----------------------------------------------------------------------------
# Internal API Key (REQUIRED)
# -----------------------------------------------------------------------------
# Used for service-to-service authentication between apps/web and backends
# SECURITY: Must be at least 32 characters for cryptographic strength
# Generate with: openssl rand -hex 32
INTERNAL_API_KEY=

# -----------------------------------------------------------------------------
# Beacon Token Secret (OPTIONAL, falls back to INTERNAL_API_KEY)
# -----------------------------------------------------------------------------
# Used for HMAC signing of proposal tracking beacon tokens
# If not set, INTERNAL_API_KEY is used as fallback
# SECURITY: Must be at least 32 characters for cryptographic strength
# Generate with: openssl rand -hex 32
# BEACON_SECRET=

# -----------------------------------------------------------------------------
# Clerk Webhooks (REQUIRED for user sync)
# -----------------------------------------------------------------------------
# Webhook signing secret from Clerk Dashboard > Webhooks
# SECURITY: Required for webhook signature verification
CLERK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# =============================================================================
# REQUIRED FOR SPECIFIC FEATURES
# =============================================================================
# These are required when using specific features. The app will start without
# them, but the related features will fail at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# AI Features (REQUIRED for proposal generation, content analysis)
# -----------------------------------------------------------------------------
# Get from https://console.anthropic.com/settings/keys
# Required for: Voice analysis, keyword intelligence, proposal generation
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE

# -----------------------------------------------------------------------------
# Stripe (REQUIRED for payments/billing)
# -----------------------------------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
# Required for: Payment processing, subscription management, invoicing
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# -----------------------------------------------------------------------------
# Google OAuth (REQUIRED for GSC/Analytics integration)
# -----------------------------------------------------------------------------
# Get from https://console.cloud.google.com/apis/credentials
# Required for: Google Search Console, Google Analytics 4 integration
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-YOUR_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Email Service (REQUIRED for notifications)
# -----------------------------------------------------------------------------
# Get from https://resend.com/api-keys
# Required for: Alert notifications, user invitations, reports
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# =============================================================================
# OPTIONAL
# =============================================================================
# These enhance functionality but are not required to start or use the app.
# =============================================================================

# -----------------------------------------------------------------------------
# Public URLs (OPTIONAL)
# -----------------------------------------------------------------------------
# Client-side URLs for browser API calls
# Required if different from server-side URLs (e.g., through nginx proxy)

# Public Open SEO URL for client-side voice API calls
# NEXT_PUBLIC_OPEN_SEO_URL=https://app.openseo.so

# Public AI Writer URL for OAuth redirects
# NEXT_PUBLIC_AI_WRITER_URL=https://api.tevero.io

# Public app URL (used for absolute URLs in emails, etc.)
# NEXT_PUBLIC_APP_URL=https://app.tevero.io

# WebSocket URL for real-time features (alternative to NEXT_PUBLIC_METRICS_WS_URL)
# Uses /ws/ path to route through nginx to open-seo WebSocket server (port 3003)
# NEXT_PUBLIC_WS_URL=wss://seowith.tevero.lt/ws

# -----------------------------------------------------------------------------
# Rate Limiting & Proxy Security (OPTIONAL)
# -----------------------------------------------------------------------------
# Secret shared between reverse proxy and app for IP verification
# Prevents attackers from spoofing X-Forwarded-For headers
# Generate with: openssl rand -hex 32
# PROXY_SECRET=

# Set to "true" if running behind Cloudflare (trusts CF-Connecting-IP header)
# TRUST_CLOUDFLARE=false

# -----------------------------------------------------------------------------
# Health Check Authentication (OPTIONAL)
# -----------------------------------------------------------------------------
# Token for authenticated health check requests (exposes detailed metrics)
# Pass via X-Health-Token header to /api/health for full circuit breaker states
# Generate with: openssl rand -hex 32
# HEALTH_CHECK_TOKEN=

# -----------------------------------------------------------------------------
# Email Marketing (OPTIONAL)
# -----------------------------------------------------------------------------
# Get from https://app.loops.so/settings/api
# LOOPS_API_KEY=YOUR_LOOPS_API_KEY_HERE

# -----------------------------------------------------------------------------
# Sentry Error Tracking (OPTIONAL but recommended for production)
# -----------------------------------------------------------------------------
# Get DSN from https://sentry.io/settings/[org]/projects/[project]/keys/
# Server-side DSN (used in API routes and Server Components)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Client-side DSN (used in browser, exposed to client)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Sentry organization and project for source map uploads
# SENTRY_ORG=your-org
# SENTRY_PROJECT=tevero-web

# Auth token for source map uploads (get from Sentry Settings > Auth Tokens)
# SENTRY_AUTH_TOKEN=sntrys_xxx

# Enable Sentry debug mode in development (set to "true" to test)
# SENTRY_DEBUG_ENABLED=false

# -----------------------------------------------------------------------------
# Environment (OPTIONAL)
# -----------------------------------------------------------------------------
NODE_ENV=development
