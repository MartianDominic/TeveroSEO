#!/usr/bin/env sh

# SEC-01: Pre-commit Secret Detection
# Blocks commits containing potential secrets (.env files, hardcoded keys)

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Running pre-commit secret detection..."

# 1. Block .env file commits (allow .env.example)
STAGED_ENV_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.env$|\.env\.local$|\.env\.production$|\.env\.development$' || true)

if [ -n "$STAGED_ENV_FILES" ]; then
  echo "${RED}ERROR: Attempting to commit .env files:${NC}"
  echo "$STAGED_ENV_FILES"
  echo ""
  echo "Remove these files from staging:"
  echo "  git reset HEAD <file>"
  echo ""
  echo "Add them to .gitignore if not already present."
  exit 1
fi

# 2. Check for hardcoded secrets in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|py|json|yaml|yml)$' || true)

if [ -n "$STAGED_FILES" ]; then
  # Secret patterns to detect (case-insensitive where appropriate)
  SECRET_PATTERNS=(
    # API keys with common prefixes
    'sk-[a-zA-Z0-9]{20,}'           # OpenAI, Stripe secret keys
    'pk_live_[a-zA-Z0-9]{20,}'      # Stripe publishable keys
    'pk_test_[a-zA-Z0-9]{20,}'      # Stripe test keys
    'sk_live_[a-zA-Z0-9]{20,}'      # Stripe live secret keys
    'sk_test_[a-zA-Z0-9]{20,}'      # Stripe test secret keys
    'ghp_[a-zA-Z0-9]{36}'           # GitHub personal access tokens
    'gho_[a-zA-Z0-9]{36}'           # GitHub OAuth tokens
    'ghu_[a-zA-Z0-9]{36}'           # GitHub user-to-server tokens
    'ghs_[a-zA-Z0-9]{36}'           # GitHub server-to-server tokens
    'ghr_[a-zA-Z0-9]{36}'           # GitHub refresh tokens
    'AKIA[0-9A-Z]{16}'              # AWS Access Key ID
    'xox[baprs]-[0-9a-zA-Z-]{10,}'  # Slack tokens
    'AIza[0-9A-Za-z_-]{35}'         # Google API keys
    'ya29\.[0-9A-Za-z_-]+'          # Google OAuth tokens
    # Generic patterns
    'password\s*[=:]\s*["\047][^"\047]{8,}["\047]'  # password = "value"
    'api_key\s*[=:]\s*["\047][^"\047]{16,}["\047]'  # api_key = "value"
    'secret\s*[=:]\s*["\047][^"\047]{16,}["\047]'   # secret = "value"
    'token\s*[=:]\s*["\047][^"\047]{20,}["\047]'    # token = "value"
  )

  FOUND_SECRETS=0

  for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
      STAGED_CONTENT=$(git show ":$file" 2>/dev/null || true)

      for pattern in "${SECRET_PATTERNS[@]}"; do
        if echo "$STAGED_CONTENT" | grep -qE "$pattern"; then
          if [ $FOUND_SECRETS -eq 0 ]; then
            echo "${RED}ERROR: Potential secrets detected in staged files:${NC}"
            FOUND_SECRETS=1
          fi
          echo "  - $file (pattern: $pattern)"
        fi
      done
    fi
  done

  if [ $FOUND_SECRETS -eq 1 ]; then
    echo ""
    echo "Please remove hardcoded secrets and use environment variables instead."
    echo "See: CLAUDE.md for secret management guidelines."
    exit 1
  fi
fi

# 3. Run gitleaks if available (optional but recommended)
if command -v gitleaks &> /dev/null; then
  echo "Running gitleaks scan..."
  if ! gitleaks detect --staged --no-banner --redact 2>/dev/null; then
    echo "${RED}ERROR: gitleaks detected secrets in staged files${NC}"
    echo "Review the output above and remove secrets before committing."
    exit 1
  fi
  echo "${GREEN}gitleaks: No secrets detected${NC}"
else
  echo "${YELLOW}Note: gitleaks not installed. Install for enhanced secret detection:${NC}"
  echo "  brew install gitleaks  # macOS"
  echo "  https://github.com/gitleaks/gitleaks#installing"
fi

echo "${GREEN}Pre-commit secret detection passed${NC}"
exit 0
