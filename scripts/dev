#!/usr/bin/env bash
# Single command to start TeveroSEO development environment
# Usage: ./scripts/dev [command]

set -e

cd "$(dirname "$0")/.."

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

case "${1:-up}" in
  up|start)
    echo -e "${GREEN}🚀 Starting TeveroSEO development environment...${NC}"
    echo ""
    echo -e "${BLUE}Services will be available at:${NC}"
    echo "  📱 Main app (Next.js):     http://localhost:53000"
    echo "  🔍 SEO Engine:             http://localhost:53001"
    echo "  ✍️  AI-Writer API:          http://localhost:58000"
    echo "  🎨 AI-Writer UI:           http://localhost:58080"
    echo "  🐘 PostgreSQL:             localhost:54320"
    echo "  📦 Redis:                  localhost:63790"
    echo ""
    docker compose -f docker-compose.dev.yml --env-file .env.dev up --build
    ;;
  down|stop)
    echo -e "${YELLOW}Stopping all services...${NC}"
    docker compose -f docker-compose.dev.yml down
    ;;
  clean)
    echo -e "${YELLOW}Cleaning up all containers and volumes...${NC}"
    docker compose -f docker-compose.dev.yml down -v --rmi local
    ;;
  logs)
    docker compose -f docker-compose.dev.yml logs -f "${@:2}"
    ;;
  proxy)
    echo -e "${GREEN}Starting with nginx proxy at http://localhost:50080${NC}"
    docker compose -f docker-compose.dev.yml --env-file .env.dev --profile proxy up --build
    ;;
  *)
    echo "Usage: ./scripts/dev [command]"
    echo ""
    echo "Commands:"
    echo "  up, start  - Start all services (default)"
    echo "  down, stop - Stop all services"
    echo "  clean      - Stop and remove all data"
    echo "  logs       - Tail logs (add service name to filter)"
    echo "  proxy      - Start with unified nginx proxy"
    ;;
esac
